# --- general ---
OPTIONS=!tutorial

OPTIONS=name:Alice
OPTIONS=catname:Dinah
OPTIONS=dogname:Puppy
OPTIONS=horsename:Horsefly

OPTIONS=disclose:yi +a +v +g +c +o

OPTIONS=paranoid_confirmation:quit attack pray swim trap

# --- UI ---
OPTIONS=windowtype:tty

OPTIONS=force_invmenu
OPTIONS=query_menu
OPTIONS=time
OPTIONS=msghistory:200
OPTIONS=msg_window:reversed
OPTIONS=hitpointbar
OPTIONS=lit_corridor
OPTIONS=hilite_pile
OPTIONS=hilite_pet

OPTIONS=statushilites:10

OPTIONS=hilite_status:gold/always/yellow

OPTIONS=hilite_status:experience-level/changed/green/always/blue

OPTIONS=hilite_status:armor-class/down/green/up/red

OPTIONS=hilite_status:hitpoints/100%/green&bold
OPTIONS=hilite_status:hitpoints/<100%/green
OPTIONS=hilite_status:hitpoints/<60%/yellow
OPTIONS=hilite_status:hitpoints/<40%/orange
OPTIONS=hilite_status:hitpoints/<33%/red
OPTIONS=hilite_status:hitpoints/<10%/red&inverse

OPTIONS=hilite_status:power/100%/green&bold
OPTIONS=hilite_status:power/<100%/green
OPTIONS=hilite_status:power/<60%/yellow
OPTIONS=hilite_status:power/<40%/orange
OPTIONS=hilite_status:power/<33%/red
OPTIONS=hilite_status:power/<10%/red&inverse

OPTIONS=hilite_status:characteristics/up/green/down/red

OPTIONS=hilite_status:condition/major_troubles/red
OPTIONS=hilite_status:condition/minor_troubles/orange
OPTIONS=hilite_status:condition/lev/cyan/fly/cyan

OPTIONS=hilite_status:hunger/satiated/yellow
OPTIONS=hilite_status:hunger/hungry/yellow
OPTIONS=hilite_status:hunger/weak/orange
OPTIONS=hilite_status:hunger/fainting/red
OPTIONS=hilite_status:hunger/fainted/red&bold
OPTIONS=hilite_status:hunger/starved/red&inverse

OPTIONS=hilite_status:carrying-capacity/burdened/yellow
OPTIONS=hilite_status:carrying-capacity/stressed/orange
OPTIONS=hilite_status:carrying-capacity/strained/red
OPTIONS=hilite_status:carrying-capacity/overtaxed/red&bold
OPTIONS=hilite_status:carrying-capacity/overloaded/red&inverse

OPTIONS=menucolors

MENUCOLOR=" blessed "=green
MENUCOLOR=" holy "=green
MENUCOLOR=" cursed "=red
MENUCOLOR=" unholy "=red

MENUCOLOR="loadstone|wand (of|called) cancellation"=yellow&underline
MENUCOLOR="Amulet of Yendor named"=magenta&underline
MENUCOLOR="gold piece"=yellow

MENUCOLOR="(\(|, )lit\)"=nocolor&bold
MENUCOLOR=" cursed .* (\(|, )lit\)"=red&bold

# forgotten spells
#          name     level  cat     fail     retention
MENUCOLOR="[a-z ]+ +[0-9] +[a-z]+ +[0-9]+% +((91|96)%-)?100%"=green&bold
MENUCOLOR="[a-z ]+ +[0-9] +[a-z]+ +[0-9]+% +76%-100%"=green
MENUCOLOR="[a-z ]+ +[0-9] +[a-z]+ +[0-9]+% +51%-75%"=yellow
MENUCOLOR="[a-z ]+ +[0-9] +[a-z]+ +[0-9]+% +26%-50%"=orange
MENUCOLOR="[a-z ]+ +[0-9] +[a-z]+ +[0-9]+% +1%-25%"=red
MENUCOLOR="[a-z ]+ +[0-9] +[a-z]+ +[0-9]+% +\(gone\)"=nocolor&dim

MENUCOLOR="\[Unskilled\]"=white&dim
MENUCOLOR="\[Basic\]"=white
MENUCOLOR="\[Skilled\]"=blue
MENUCOLOR="\[Expert\]"=lightblue
MENUCOLOR="\[Master\]"=lightblue&bold
MENUCOLOR="\[Grand Master\]"=lightblue&inverse

# --- symbols ---
OPTIONS=symset:Enhanced1

# 0 DIGIT ZERO (Can only be set via OPTIONS)
OPTIONS=boulder:0
# · MIDDLE DOT (more visible color)
OPTIONS=glyph:G_ice/U+00B7/142-159-202

# π GREEK SMALL LETTER PI
SYMBOLS=S_altar:U+03C0
# ▓ DARK SHADE
SYMBOLS=S_engrcorr:U+2593
